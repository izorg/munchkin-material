{
  "name": "@munchkin/pwa",
  "private": true,
  "type": "module",
  "sideEffects": [
    "src/index.tsx",
    "src/polyfills.ts"
  ],
  "targets": {
    "default": {
      "distDir": "dist",
      "source": [
        "src/index.html",
        "src/localized-files/*/index.html"
      ]
    }
  },
  "scripts": {
    "analyze": "yarn build:parcel --no-cache --reporter=@parcel/reporter-bundle-analyzer --reporter=@parcel/reporter-bundle-buddy",
    "build": "yarn build:assets && yarn build:parcel && yarn build:workbox",
    "build:assets": "node scripts/build-assets.js",
    "build:parcel": "parcel build",
    "build:workbox": "workbox generateSW workbox.config.json",
    "clean": "yarn g:rimraf dist/ screenshots/ test-results/",
    "dev": "parcel --port=3000",
    "screenshots": "playwright test",
    "start": "firebase emulators:start"
  },
  "devDependencies": {
    "@parcel/packager-raw-url": "2.16.4",
    "@parcel/reporter-bundle-analyzer": "2.16.4",
    "@parcel/reporter-bundle-buddy": "2.16.4",
    "@parcel/transformer-webmanifest": "2.16.4",
    "@playwright/test": "1.60.0",
    "@sentry/react": "10.53.1",
    "@types/node": "25.9.1",
    "@types/parcel-env": "0.0.9",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "core-js": "3.49.0",
    "firebase-tools": "15.18.0",
    "handlebars": "4.7.9",
    "parcel": "2.16.4",
    "playwright": "1.60.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-router": "7.15.1",
    "workbox-cli": "7.4.1"
  }
}
