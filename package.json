{
  "private": true,
  "name": "munchkin",
  "version": "16.1.9",
  "type": "module",
  "packageManager": "yarn@4.13.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "check": "yarn check-knip && yarn check-prettier && yarn check-types && yarn check-eslint && yarn check-oxlint && yarn check-stylelint",
    "check-eslint": "eslint --cache",
    "check-knip": "knip --cache",
    "check-oxlint": "oxlint",
    "check-prettier": "prettier --cache --check --ignore-unknown .",
    "check-stylelint": "stylelint --cache \"**/*.css\"",
    "check-types": "tsc",
    "clean-cache": "rm -rf .parcel-cache",
    "format": "prettier --cache --ignore-unknown --write .",
    "get-version": "node --no-warnings scripts/version.js",
    "postinstall": "husky || true",
    "reinstall": "rm -r node_modules yarn.lock && yarn install",
    "g:rimraf": "cd $INIT_CWD && rimraf"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@eslint-community/eslint-plugin-eslint-comments": "4.7.1",
    "@eslint/compat": "2.0.5",
    "@eslint/css": "1.1.0",
    "@eslint/js": "9.39.4",
    "@eslint/json": "1.2.0",
    "@next/eslint-plugin-next": "16.2.3",
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/github": "12.0.6",
    "@semantic-release/release-notes-generator": "14.1.0",
    "@types/node": "24.12.2",
    "conventional-changelog-conventionalcommits": "9.3.1",
    "eslint": "9.39.4",
    "eslint-config-flat-gitignore": "2.3.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-compat": "7.0.1",
    "eslint-plugin-formatjs": "6.4.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jest": "29.15.1",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-only-error": "1.0.2",
    "eslint-plugin-perfectionist": "5.8.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-unicorn": "64.0.0",
    "globals": "17.4.0",
    "husky": "9.1.7",
    "knip": "6.3.1",
    "lint-staged": "16.4.0",
    "oxlint": "1.59.0",
    "prettier": "3.8.1",
    "rimraf": "6.1.3",
    "semantic-release": "25.0.3",
    "stylelint": "17.6.0",
    "stylelint-config-standard": "40.0.0",
    "stylelint-order": "8.1.1",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.1"
  },
  "alias": {
    "@formatjs/icu-messageformat-parser": "@formatjs/icu-messageformat-parser/no-parser.js",
    "process": false
  },
  "@parcel/resolver-default": {
    "packageExports": true
  }
}
